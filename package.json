{
  "name": "qwacky",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.8.0",
    "react-markdown": "^10.1.0",
    "styled-components": "^5.3.9",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.228",
    "@types/node": "^18.15.0",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@types/styled-components": "^5.1.26",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^4.9.5",
    "vite": "^6.2.2",
    "archiver": "^7.0.1"
  },
  "scripts": {
    "predev": "node scripts/update-version.js",
    "dev": "vite build --watch --mode development",
    "predev:firefox": "node scripts/update-version.js",
    "dev:firefox": "vite build --watch --mode firefox",
    "prebuild": "node scripts/update-version.js",
    "build": "tsc && vite build --mode production",
    "prebuild:firefox": "node scripts/update-version.js",
    "build:firefox": "tsc && vite build --mode firefox",
    "preview": "vite preview",
    "clean": "rm -rf dist_chrome dist_firefox",
    "update-version": "node scripts/update-version.js",
    "package:chrome": "npm run build && node scripts/package.js chrome",
    "package:firefox": "npm run build:firefox && node scripts/package.js firefox",
    "package": "npm run package:chrome && npm run package:firefox"
  }
}
